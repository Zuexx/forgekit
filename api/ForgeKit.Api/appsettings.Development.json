{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "LuckyPennySoftware.Themes": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithProperty"
    ],
    "Properties": {
      "Application": "ForgeKit.Api"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=./data/forgekit.db",
    "Postgres": "Host=localhost;Database=forgekit_db",
    "SqlServer": "Server=localhost;Database=forgekit_db;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "AllowedHosts": "*",
  "JwtData": {
    "Issuer": "http://localhost:5000",
    "Audience": "http://localhost:3000"
  },
  "SMTP": {
    "From": "noreply@example.com",
    "Password": "",
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587
  },
  "JwksCallBackUrl": {
    "Base": "http://localhost:3000",
    "Jwks": "http://localhost:3000/api/auth/jwks"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173",
      "http://localhost:8080"
    ]
  }
}
