# EditorConfig is awesome: https://EditorConfig.org

root = true

# All files
[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# C# files
[*.cs]
indent_size = 4
max_line_length = 120

# JSON
[*.json]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# TypeScript/JavaScript
[*.{ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 100

# Markdown
[*.md]
trim_trailing_whitespace = false
